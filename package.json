{
  "name": "weather-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "cd frontend && ng",
    "build": "cd frontend && ng build",
    "watch": "cd frontend && ng build --watch --configuration development",
    "test": "cd frontend && ng test",
    "serve:ssr:weather-angular": "cd frontend && node dist/weather-angular/server/server.mjs",
    "start:frontend": "cd frontend && ng serve --configuration development",
    "start:backend": "cd backend && node server.js",
    "dev": "concurrently --names \"ANGULAR,NODE\" \"npm run start:frontend\" \"npm run start:backend\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/platform-server": "^17.0.0",
    "@angular/router": "^17.0.0",
    "@angular/ssr": "^17.0.8",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.8",
    "@angular/cli": "^17.0.8",
    "@angular/compiler-cli": "^17.0.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.2.2"
  },
  "description": "<h1 align=\"center\">WeatherAngular</h1>",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dancsims/weather-angular.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dancsims/weather-angular/issues"
  },
  "homepage": "https://github.com/dancsims/weather-angular#readme"
}
